<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Draw the motion cues over other apps. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- Keep the overlay alive while the user is in another app. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- Show the persistent "cues active" notification (Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application>
        <service
            android:name=".MotionOverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Floating motion-sickness accessibility cues drawn over other apps." />
        </service>

        <!-- Optional: lets the user toggle cues from the system Accessibility
             menu. Enabled by the user, not required for the overlay to work. -->
        <service
            android:name=".MotionStabilizerAccessibilityService"
            android:exported="false"
            android:label="Motion Sickness Stabilizer Cues"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>
    </application>
</manifest>
